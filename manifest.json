{
  "manifest_version": 3,
  "name": "DarkAbsolut",
  "version": "1.0.0",
  "description": "Automatically applies a dark theme to websites that don't already have one. Smart detection avoids inverting already-dark sites.",
  "permissions": ["storage", "activeTab", "scripting"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_title": "DarkAbsolut",
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_ui": {
    "page": "popup/options.html",
    "open_in_tab": true
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "src/background/index.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": [
        "src/content/00-namespace.js",
        "src/content/colors.js",
        "src/content/detect.js",
        "src/content/styles.js",
        "src/content/elements.js",
        "src/content/controller.js"
      ],
      "run_at": "document_start",
      "all_frames": true,
      "match_about_blank": false
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["invert.css"],
      "matches": ["<all_urls>"]
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "darkabsolut@local.extension",
      "strict_min_version": "121.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  }
}
